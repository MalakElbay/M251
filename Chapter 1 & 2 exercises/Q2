import java.util.Scanner;
public class Main{
    public static char grade(int a, int b, int c){
        int sum = a+b+c;
        if (sum>=90)
            return 'A';
        else if (sum>=80)
            return 'B';
        else if (sum>=70)
            return 'C';
        else if (sum>=60)
            return 'D';
        else
            return 'F';
    }
    public static void main(String[] args) {
        Scanner input = new Scanner(System.in);
        System.out.print("Insert the number of students: ");
        int n = input.nextInt();
        for (int i = 1; i <= n; i++) {
            System.out.printf("Insert TMA score for student %d: ", i);
            int tma = input.nextInt();
            System.out.printf("Insert MTA score for student %d: ", i);
            int mta = input.nextInt();
            System.out.printf("Insert final exam score for student %d: ", i);
            int fin = input.nextInt();
            System.out.printf("Grade = %c%n", grade(tma, mta, fin));
        }
    }
}
