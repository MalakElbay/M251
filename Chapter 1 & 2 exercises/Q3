import java.util.Scanner;
public class Main{
    public static double computeAverage(int[] scores){
        int sum = 0;
        for (int i = 0 ; i<scores.length ; i++)
            sum+=scores[i];
        return (double)sum/scores.length;
    }
    public static int computeMax(int[] scores){
        int max = -1;
        int index = -1;
        for (int i = 0 ; i<scores.length ; i++){
            if (max<scores[i]) {
                max = scores[i];
                index = i;
            }
        }
        return index;
    }
    public static double percentageOfSuccess(int[] scores){
        int total =0;
        for (int i =0 ; i<scores.length ; i++){
            if (scores[i] >= 50)
                total++;
        }
        double p = ((double)total/scores.length)*100;
        return p;
    }
    public static void main(String[] args) {
        Scanner input = new Scanner(System.in);
        System.out.print("Insert the number of students: ");
        int n = input.nextInt();
        int[] arr= new int[n];
        System.out.print("Insert the scores of the students: ");
        for (int i = 0 ; i<n ; i++){
            arr[i] = input.nextInt();
        }
        System.out.printf("The average of the scores is: %.2f%n", computeAverage(arr));
        System.out.printf("The maximum score is %d%n", arr[computeMax(arr)]);
        System.out.printf("The percentage of success is: %.2f", percentageOfSuccess(arr));
    }
}
