public class Machine {
    private boolean power;
    private String brandName;

    public Machine(){
    }
    public Machine(boolean newPower, String newBrandName){
        power = newPower;
        brandName= newBrandName;
    }
    
    public Boolean getPower(){
        return power;
    }
    public String getBrandName(){
        return brandName;
    }
    public void setBrandName(String newBrandName){
        brandName= newBrandName;
    }
    public void switchOn(){
        power = true;
    }
    public void switchOff(){
        power = false;
    }
    public void display(){
        if (power)
            System.out.printf("%s machine is powered On\n", brandName);
        else
            System.out.printf("%s machine is powered OFF\n", brandName);
    }

    @Override
    public String toString(){
        return "Brand name: " + brandName + ", Is the power on: " + power;
    }
}
