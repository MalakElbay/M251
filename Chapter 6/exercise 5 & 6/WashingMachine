public class WashingMachine extends Machine implements Comparable<WashingMachine>{
    private Date productionDate = new Date();
    private long capacity = 1;

    public WashingMachine(){

    }
    public WashingMachine(boolean power, String name,  Date productionDate, long capacity){
        super(power, name);
        this.productionDate = productionDate;
        this.capacity = capacity;
    }

    public Date getProductionDate(){
        return this.productionDate;
    }
    public void setProductionDate(int day, int month, int year){
        productionDate.setDay(day);
        productionDate.setMonth(month);
        productionDate.setYear(year);
    }

    public long getCapacity(){
        return capacity;
    }
    public void setCapacity(long capacity){
        this.capacity = capacity;
    }

    @Override
    public String toString(){
        return super.toString() + ", Production date: " + productionDate + ", Capacity is: " + capacity;
    }

    @Override
    public boolean equals(Object o){
        if(o instanceof WashingMachine) {
            WashingMachine wm = (WashingMachine) o;
            return wm.getBrandName().equals(this.getBrandName()) && wm.getProductionDate().equals(this.productionDate);
        }
        return false;
    }

    @Override
    public int compareTo(WashingMachine wm){
        int brandNameCompare = this.getBrandName().compareTo(wm.getBrandName());
        if(brandNameCompare!=0)
            return brandNameCompare;
        if (this.capacity > wm.capacity)
            return 1;
        else if(this.capacity < wm.capacity)
            return -1;
        else
            return 0;
    }
}
