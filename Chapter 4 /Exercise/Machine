public class Machine {
    private String brandName;
    private boolean power;

    Machine(){

    }
    Machine(String brandName, boolean power){
        this.brandName = brandName;
        this.power = power;
    }
    public void setBrandName(String brandName){
        this.brandName = brandName;
    }
    public String getBrandName(){
        return brandName;
    }
    public boolean getPower(){
        return power;
    }
    public void switchOn(){
        this.power = true;
    }
    public void switchOff(){
        this.power = false;
    }

    public void display(){
        System.out.println("The brand name of the machine: " + brandName + ", is the machine turned on: "+ power);
    }

}
