public class TV {
    int channel = 1;
    int volumeLevel = 1;
    boolean isOn = false;

    public TV() {}

    public void turnOn() {
        isOn = true;
    }
    public void turnOff(){
        isOn = false;
    }

    public void setChannel(int newChannel){
        if(isOn)
            if(newChannel >=1 && newChannel <=120){
                channel = newChannel;
            }
    }

    public void channelUp(){
        if (isOn)
            if(channel < 120)
                channel++;
    }
    public void channelDown(){
        if (isOn)
            if(channel > 1)
                channel--;
    }
    public void setVolume(int newVolumeLevel){
        if (isOn)
            if(newVolumeLevel>=1 && newVolumeLevel<=7)
                volumeLevel= newVolumeLevel;
    }
    public void volumeUp(){
        if(isOn)
            if(volumeLevel<7)
                volumeLevel++;
    }
    public void volumeDown(){
        if(isOn)
            if(volumeLevel>1)
                volumeLevel--;
    }
}
