public class Room {
    private int roomNumber;
    private int roomCapacity;
    private boolean inLab;

    public Room (int roomNumber, int roomCapacity, boolean inLab){
        this.roomNumber = roomNumber;
        this.roomCapacity = roomCapacity;
        this.inLab = inLab;
    }

    public int getRoomNumber(){
        return roomNumber;
    }
    public void setRoomNumber(int roomNumber){
        this.roomNumber = roomNumber;
    }

    public int getRoomCapacity(){
        return roomCapacity;
    }
    public void setRoomCapacity(int roomCapacity){
        this.roomCapacity = roomCapacity;
    }

    public boolean isInLab(){
        return inLab;
    }
    public void setInLab(boolean inLab){
        this.inLab = inLab;
    }

    @Override
    public String toString(){
        return "Room number: "+ roomNumber +" ,  Room capacity: " + roomCapacity +" , Is the room stored in a lab: " + inLab;
    }

    @Override
    public boolean equals(Object o){
        if (o instanceof Room){
            Room r = (Room)o;
            return roomNumber == r.roomNumber;
        }
        return false;
    }
}
