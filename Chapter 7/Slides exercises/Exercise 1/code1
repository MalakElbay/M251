import java.util.*;
import java.io.*;
public class Main {
    public static void main(String[] args) {
        try {
            File fr = new File("C:/Users....../luck.txt"); //<- add yo file path here 
            Scanner input = new Scanner(fr);
            int count = 0;
            while(input.hasNextLine()){
                System.out.println(input.nextLine());
                count++;
            }
            input.close();
            System.out.printf("The file has %d lines", count);
        }
        catch(FileNotFoundException e){
            System.out.println("error: " + e);
        }
    }
}
